      "cell_type": "code",
      "source": [
        "import numpy as np\n",
        "import pandas as pd\n",
        "\n",
        "# -----------------------------\n",
        "# Reproducibility\n",
        "# -----------------------------\n",
        "np.random.seed(42)\n",
        "\n",
        "# -----------------------------\n",
        "# Parameters\n",
        "# -----------------------------\n",
        "n_genes = 1000\n",
        "n_samples = 20\n",
        "n_deg = 100  # differentially expressed genes\n",
        "\n",
        "# Sample labels\n",
        "conditions = ['Tumor'] * 10 + ['Normal'] * 10\n",
        "samples = [f\"Sample_{i+1}\" for i in range(n_samples)]\n",
        "\n",
        "# Gene names\n",
        "genes = [f\"Gene_{i+1}\" for i in range(n_genes)]\n",
        "\n",
        "# -----------------------------\n",
        "# Step 1: Simulate RAW COUNTS (integer)\n",
        "# -----------------------------\n",
        "counts = np.random.poisson(lam=50, size=(n_genes, n_samples))\n",
        "\n",
        "# -----------------------------\n",
        "# Step 2: Convert to FLOAT for transformations\n",
        "# -----------------------------\n",
        "expression = counts.astype(float)\n",
        "\n",
        "# -----------------------------\n",
        "# Step 3: Introduce Differential Expression\n",
        "# -----------------------------\n",
        "deg_indices = np.random.choice(n_genes, n_deg, replace=False)\n",
        "\n",
        "for gene in deg_indices:\n",
        "    if np.random.rand() > 0.5:\n",
        "        # Upregulated in Tumor\n",
        "        fold_change = np.random.uniform(1.5, 3.0)\n",
        "    else:\n",
        "        # Downregulated in Tumor\n",
        "        fold_change = np.random.uniform(0.3, 0.7)\n",
        "\n",
        "    expression[gene, :10] *= fold_change  # first 10 = Tumor\n",
        "\n",
        "# -----------------------------\n",
        "# Step 4: Create DataFrames\n",
        "# -----------------------------\n",
        "counts_df = pd.DataFrame(counts, index=genes, columns=samples)\n",
        "expr_df = pd.DataFrame(expression, index=genes, columns=samples)\n",
        "\n",
        "# -----------------------------\n",
        "# Step 5: Metadata\n",
        "# -----------------------------\n",
        "metadata = pd.DataFrame({\n",
        "    'Sample': samples,\n",
        "    'Condition': conditions\n",
        "})\n",
        "\n",
        "# -----------------------------\n",
        "# Step 6: Save files\n",
        "# -----------------------------\n",
        "counts_df.to_csv(\"gene_expression_raw_counts.csv\")\n",
        "expr_df.to_csv(\"gene_expression_transformed.csv\")\n",
        "metadata.to_csv(\"sample_metadata.csv\", index=False)\n",
        "\n"
      ],
